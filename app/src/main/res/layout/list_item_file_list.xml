<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    xmlns:app="http://schemas.android.com/apk/res-auto">
    <com.appbroker.roundedimageview.RoundedImageView
        android:id="@+id/list_item_file_icon"
        android:layout_width="100dp"
        android:layout_height="30dp"
        android:src="@drawable/image1"
        android:scaleType="fitXY"
        app:radius="5dp"
        android:layout_alignParentLeft="true"
        android:layout_centerVertical="true"
        android:layout_margin="5dp"/>
    <ImageView
        android:id="@+id/list_item_file_more"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_alignParentRight="true"
        android:src="@drawable/ic_baseline_more_vert_24"
        android:layout_centerVertical="true"
        android:clickable="true"
        android:focusable="true"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:layout_marginRight="5dp"
        android:layout_marginLeft="5dp"/>
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_toLeftOf="@id/list_item_file_more"
        android:layout_centerVertical="true"
        android:layout_toRightOf="@id/list_item_file_icon"
        android:orientation="vertical"
        android:layout_margin="2dp">
        <TextView
            android:id="@+id/list_item_file_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="16sp"
            android:textStyle="bold"
            android:text="Darude Sandstorm"/>
        <TextView
            android:id="@+id/list_item_file_duration"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="12sp"
            android:text="3:03"/>
    </LinearLayout>
</RelativeLayout>